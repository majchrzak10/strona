# ============================================================
#  Dan-Dom Nieruchomości — Apache config dla Cyberfolks
#  Next.js static export (output: "export", trailingSlash: true)
# ============================================================

Options -Indexes
DirectoryIndex index.html

# --- HTTPS redirect ------------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# --- Listy: stare ścieżki → jedna strona z ?typ= (301, QSA zachowuje np. ?kat=) ---
RewriteRule ^nieruchomosci/sprzedaz/?$ /nieruchomosci/?typ=sprzedaz [R=301,L,QSA]
RewriteRule ^nieruchomosci/wynajem/?$ /nieruchomosci/?typ=wynajem [R=301,L,QSA]

# --- www → bez www ------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# --- Obsługa tras Next.js (trailingSlash: true) --------------
# Przekieruj /oferty do /oferty/ (jeśli brak slash)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

# Serwuj index.html dla katalogów
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)$ $1/index.html [L]

# Fallback — 404.html z Next.js
ErrorDocument 404 /404/index.html

# --- Cache: HTML zawsze świeży (index.html w każdym katalogu = strony Next export) ---
# Jeśli hosting ma LiteSpeed Cache w panelu — wyczyść cache po deployu lub wyłącz dla tej domeny.
<IfModule mod_headers.c>
  # Wszystkie index.html (główna, /oferty/, /oferty/slug/, …)
  <Files "index.html">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header unset ETag
  </Files>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

# --- Kompresja gzip ------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# --- Bezpieczeństwo (nagłówki HTTP) --------------------------
# Przy `output: export` obowiązuje serwer (Apache), nie next.config — patrz też komentarz w next.config.ts.
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  # HSTS tylko po HTTPS
  Header always set Strict-Transport-Security "max-age=31536000" env=HTTPS
  # Statyczny Next + Web3Forms + GA4 (gtag) + obrazy https:. Przy problemach z zasobami — tymczasowo zakomentuj CSP.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://api.web3forms.com https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://www.googletagmanager.com; manifest-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests"
</IfModule>
