# Eksport Asari (oferty z XML). Ścieżka absolutna (Windows: C:/...) lub względna do projektu.
# Zalecane: skopiuj XML do folderu asari-export/ w projekcie i ustaw:
ASARI_DATA_DIR=asari-export
ASARI_PHOTOS_DIR=asari-export/foto
#
# Jeśli eksport jest gdzie indziej na dysku — pełna ścieżka, np.:
# ASARI_DATA_DIR=D:/EksportAsari/asari
# ASARI_PHOTOS_DIR=D:/EksportAsari/asari/foto
#
# Usuń błędne wartości z „Zmiennych środowiskowych” Windows — mogą nadpisać .env.local.

# ─── Domena (kanoniczne URL, sitemap, OG) ──────────────────────────────────
# Domyślnie (gdy puste): https://dan-dom.pl
# Testy na stagingu, np. bioredlab.pl:
# NEXT_PUBLIC_SITE_URL=https://bioredlab.pl
#
# Skróty (Windows / Mac / Linux):
#   npm run build:staging   → bioredlab.pl
#   npm run build:prod      → dan-dom.pl (jawnie)
#   npm run build           → jak w .env.local lub domyślnie dan-dom.pl
#
# Indeksowanie Google: na stagingu (bioredlab.pl) wyłączane jest automatycznie (noindex + robots disallow).
# Wymuszenie ręczne na dowolnej domenie:
# NEXT_PUBLIC_SITE_NOINDEX=true

# ─── Formularz kontaktowy (Web3Forms) ─────────────────────────────────────
# 1) Załóż konto: https://web3forms.com  →  dodaj adres odbiorcy (np. biuro@dan-dom.pl)
# 2) Skopiuj „Access Key” i wklej poniżej (bez cudzysłowów).
# 3) Lokalnie: zapisz jako .env.local (ten plik jest w .gitignore).
# 4) Produkcja (GitHub Actions): dodaj sekret WEB3FORMS_ACCESS_KEY z tym samym kluczem
#    (workflow mapuje go na NEXT_PUBLIC_* przy buildzie).
# 5) Antyspam: w panelu Web3Forms włącz honeypot / limit; przy dużym spamie rozważ CAPTCHA.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# ─── Google Analytics 4 (opcjonalnie) ───────────────────────────────────────
# GA: Administracja → Strumienie danych → Measurement ID (G-xxxxxxxx).
# Bez tej zmiennej skrypt GA nie jest ładowany. Ładowanie po zgodzie w banerze cookies (CookieConsentRoot).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# (Opcja alternatywna — własny backend + Resend; nieużywane przy Web3Forms)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Dan-Dom <onboarding@resend.dev>"

# WordPress → wtyczka Webist WP Asari CRM → Konkurencja: opcjonalny most HTTP (Node).
# Lokalnie: cd tools/competitor-bridge && npm start  →  wpisz w WP URL bez końcowego /search, np. http://127.0.0.1:3847
# PORT=3847
